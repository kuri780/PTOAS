module {
  func.func @cube_kernel(%0: !pto.ptr<f32, gm>) attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %1 = pto.reserve_buffer{name = "v2c_fifo_subblock", size = 4096, location = <mat>, auto = true} -> i32
    %2 = pto.import_reserved_buffer{name = "c2v_fifo_subblock", peer_func = @vector_kernel} -> i32
    pto.aic_initialize_pipe {id = 0, dir_mask = 3, slot_size = 1024}(gm_slot_buffer = %0 : !pto.ptr<f32, gm>, c2v_consumer_buf = %2 : i32, v2c_consumer_buf = %1 : i32)
    %3 = pto.alloc_tile : !pto.tile_buf<acc, 16x16xf32, blayout=col_major, slayout=row_major, fractal=1024>
    pto.tpush_to_aiv(%3 : !pto.tile_buf<acc, 16x16xf32, blayout=col_major, slayout=row_major, fractal=1024>) { split = 1}
    %5 = pto.tpop_from_aiv { split = 1} -> !pto.tile_buf<mat, 16x16xf32, blayout=col_major, slayout=row_major>
    pto.tfree_from_aiv { split = 1}
    return
  }
  func.func @vector_kernel(%0: !pto.ptr<f32, gm>) attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %1 = pto.reserve_buffer{name = "c2v_fifo_subblock", size = 4096, location = <vec>, auto = true} -> i32
    %2 = pto.import_reserved_buffer{name = "v2c_fifo_subblock", peer_func = @cube_kernel} -> i32
    pto.aiv_initialize_pipe {id = 0, dir_mask = 3, slot_size = 1024}(gm_slot_buffer = %0 : !pto.ptr<f32, gm>, c2v_consumer_buf = %1 : i32, v2c_consumer_buf = %2 : i32)
    %3 = pto.get_subblock_idx
    %5 = pto.alloc_tile : !pto.tile_buf<vec, 8x16xf32>
    pto.tpush_to_aic(%5 : !pto.tile_buf<vec, 8x16xf32>) { split = 1} aiv_subblockid(%3)
    %12 = pto.tpop_from_aic { split = 1} aiv_subblockid(%3) -> !pto.tile_buf<vec, 8x16xf32>
    pto.tfree_from_aic { split = 1}
    return
  }
  func.func @internal_aiv_subblockid(%0: !pto.ptr<f32, gm>) attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %1 = pto.reserve_buffer{name = "internal_subblock_local", size = 4096, location = <vec>, auto = true} -> i32
    %2 = pto.reserve_buffer{name = "internal_subblock_peer", size = 4096, location = <vec>, auto = true} -> i32
    %3 = pto.initialize_l2g2l_pipe{dir_mask = 3, slot_size = 1024, slot_num = 4, local_slot_num = 2, flag_base = 6, nosplit = false} (%0 : !pto.ptr<f32, gm>, %1 : i32, %2 : i32) -> !pto.pipe
    %5 = pto.get_subblock_idx
    %12 = pto.alloc_tile : !pto.tile_buf<vec, 8x16xf32>
    pto.tpush(%12, %3 : !pto.tile_buf<vec, 8x16xf32>, !pto.pipe) {split = 1} aiv_subblockid(%5)
    %20 = pto.declare_tile -> !pto.tile_buf<vec, 8x16xf32>
    pto.tpop(%20, %3 : !pto.tile_buf<vec, 8x16xf32>, !pto.pipe) {split = 1} aiv_subblockid(%5)
    pto.tfree(%3 : !pto.pipe) {split = 1}
    return
  }
}
