// RUN: ./bin/ptoas --enable-insert-sync %s 2>&1 1>/dev/null | FileCheck %s

// This test models the PyPTO expectation for intra-pipe dependencies:
// when two ops run on the same pipe (here: PIPE_V) and have a true memory
// dependency, InsertSync should materialize a per-pipe barrier instead of
// ignoring the dependency.

module {
  // CHECK-LABEL: func.func @test_intra_pipe_barrier
  // CHECK: pto.tadd
  // CHECK: pto.barrier <PIPE_V>
  // CHECK: pto.tadd
  // CHECK: pto.barrier <PIPE_ALL>
  func.func @test_intra_pipe_barrier() {
    %ub0 = pto.alloc_tile : !pto.tile_buf<vec, 16x16xf16>
    %ub1 = pto.alloc_tile : !pto.tile_buf<vec, 16x16xf16>

    // Both ops are on PIPE_V and touch %ub0, so there is an intra-pipe RAW/WAW
    // hazard that must be serialized by a per-pipe barrier.
    pto.tadd ins(%ub0, %ub0 : !pto.tile_buf<vec, 16x16xf16>, !pto.tile_buf<vec, 16x16xf16>)
             outs(%ub0 : !pto.tile_buf<vec, 16x16xf16>)
    pto.tadd ins(%ub0, %ub0 : !pto.tile_buf<vec, 16x16xf16>, !pto.tile_buf<vec, 16x16xf16>)
             outs(%ub1 : !pto.tile_buf<vec, 16x16xf16>)
    return
  }
}
