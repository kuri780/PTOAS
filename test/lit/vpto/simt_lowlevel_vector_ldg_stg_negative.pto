// RUN: not ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t 2>&1 | FileCheck %s

// Test that pto.ldg rejects unsupported vector types.
// Representative case: vector<4xf32> — only 2-element vectors are supported.

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @bad_v4f32(%gm: !pto.ptr<vector<4xf32>, gm>) attributes {pto.aicore} {
    %c0 = arith.constant 0 : index
    %v = pto.ldg %gm[%c0] l1cache(cache) l2cache(nmfv) : !pto.ptr<vector<4xf32>, gm> -> vector<4xf32>
    return
  }
}

// CHECK: vector<2xf16>/vector<2xbf16>/vector<2xf32> value type
