// RUN: ptoas --cann-output-version=9.0.0 --pto-arch=a5 --pto-backend=vpto --emit-vpto-llvm-ir %s -o - 2>&1 | FileCheck %s

// Verify that pto.print is lowered to inline DebugTunnel protocol via LLVM
// CFG (not @printf) when using the VPTO backend.

// CHECK: @_ptoas_printf_fmt_0 = private constant [18 x i8] c"scalar = %+08.3f\0A\00"

// CHECK: declare i64 @llvm.hivm.GET.BLOCK.IDX()
// CHECK: declare void @llvm.hivm.DCCI(ptr addrspace(1), i64)
// CHECK: declare ptr @llvm.hivm.get.sycl.fix.stack.object()

// CHECK: define void @print_scalar_kernel_mix_aiv(float
// CHECK-SAME: ptr addrspace(1) %1

// CHECK: call ptr @llvm.hivm.get.sycl.fix.stack.object()
// CHECK: store i64 {{.*}}, ptr {{.*}}, align 4
// CHECK: store i32 2, ptr addrspace(1) {{.*}}, align 4

// CHECK: getelementptr i8, ptr addrspace(1) %1, i32 24
// CHECK: call i64 @llvm.hivm.GET.BLOCK.IDX()

// CHECK: store i8 2, ptr addrspace(1) {{.*}}, align 1
// CHECK: bitcast float %0 to i32
// CHECK: call void @llvm.hivm.DCCI(ptr addrspace(1) null, i64 1)

// CHECK: !hivm.annotations = !{
// CHECK-SAME: !"kernel", i32 1

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @print_scalar_kernel(%arg0: f32) attributes {pto.entry} {
    pto.print ins("scalar = %+08.3f\n", %arg0 : f32)
    return
  }
}
