// RUN: split-file %s %t
// RUN: not ptoas --pto-arch=a5 %t/req8_scalar_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_SCALAR
// RUN: not ptoas --pto-arch=a5 %t/qf322b8_pre_scalar_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_SCALAR
// RUN: not ptoas --pto-arch=a5 %t/qf322f16_pre_scalar_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_SCALAR
// RUN: not ptoas --pto-arch=a5 %t/qf322bf16_pre_scalar_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_SCALAR
// RUN: not ptoas --pto-arch=a5 %t/qs322bf16_pre_scalar_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_SCALAR
// RUN: not ptoas --pto-arch=a5 %t/qf322hif8_pre_scalar_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_SCALAR
// RUN: not ptoas --pto-arch=a5 %t/qf322fp8_pre_scalar_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_SCALAR
// RUN: not ptoas --pto-arch=a5 %t/req8_vec_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_VECTOR
// RUN: not ptoas --pto-arch=a5 %t/qf322b8_pre_vec_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_VECTOR
// RUN: not ptoas --pto-arch=a5 %t/qs322bf16_pre_vec_missing.pto 2>&1 | FileCheck %s --check-prefix=MISSING_VECTOR
// RUN: not ptoas --pto-arch=a5 %t/scalar_wrong_existing_id.pto 2>&1 | FileCheck %s --check-prefix=WRONG_SCALAR_ID
// RUN: not ptoas --pto-arch=a5 %t/vector_wrong_existing_id.pto 2>&1 | FileCheck %s --check-prefix=WRONG_VECTOR_ID

// MISSING_SCALAR: error: 'pto.tpush_to_aiv' op expects a preceding pto.set_quant_scalar with id = 0 in the same block
// MISSING_VECTOR: error: 'pto.tpush_to_aiv' op expects a preceding pto.set_quant_vector with id = 0 in the same block
// WRONG_SCALAR_ID: error: 'pto.tpush_to_aiv' op expects a preceding pto.set_quant_scalar with id = 0 in the same block
// WRONG_VECTOR_ID: error: 'pto.tpush_to_aiv' op expects a preceding pto.set_quant_vector with id = 0 in the same block

//--- req8_scalar_missing.pto
module {
  func.func @cube_kernel() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c0_i32 = arith.constant 0 : i32
    %c2v_import = pto.import_reserved_buffer {name = "c2v_fifo", peer_func = @vector_kernel} -> i32
    pto.aic_initialize_pipe {id = 0, dir_mask = 1, slot_size = 256, nosplit = true,
      acc_push_epilogue = #pto.acc_push_epilogue<layout = nz2nd, quant = req8_scalar, relu = no_relu>}
      (c2v_consumer_buf = %c2v_import : i32, v2c_consumer_buf = %c0_i32 : i32)
    %acc = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=i32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    pto.tpush_to_aiv(%acc : !pto.tile_buf<loc=acc, dtype=i32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>) {id = 0, split = 0}
    return
  }
  func.func @vector_kernel() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0_i32 = arith.constant 0 : i32
    %c2v_local = pto.reserve_buffer {name = "c2v_fifo", size = 4096, location = #pto.address_space<vec>, auto = true} -> i32
    pto.aiv_initialize_pipe {id = 0, dir_mask = 1, slot_size = 256, nosplit = true,
      acc_push_epilogue = #pto.acc_push_epilogue<layout = nz2nd, quant = req8_scalar, relu = no_relu>}
      (c2v_consumer_buf = %c2v_local : i32, v2c_consumer_buf = %c0_i32 : i32)
    %recv = pto.tpop_from_aic {id = 0, split = 0}
      -> !pto.tile_buf<loc=vec, dtype=ui8, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tfree_from_aic {id = 0, split = 0}
    return
  }
}

