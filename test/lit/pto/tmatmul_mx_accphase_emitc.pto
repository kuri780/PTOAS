// A5: TMATMUL_MX([[D3:[_A-Za-z][_A-Za-z0-9]*]], [[C3:[_A-Za-z][_A-Za-z0-9]*]], [[A3:[_A-Za-z][_A-Za-z0-9]*]], [[AS3:[_A-Za-z][_A-Za-z0-9]*]], [[B3:[_A-Za-z][_A-Za-z0-9]*]], [[BS3:[_A-Za-z][_A-Za-z0-9]*]]);
// A5: TMATMUL_MX<pto::AccPhase::Partial>([[D4:[_A-Za-z][_A-Za-z0-9]*]], [[C4:[_A-Za-z][_A-Za-z0-9]*]], [[A4:[_A-Za-z][_A-Za-z0-9]*]], [[AS4:[_A-Za-z][_A-Za-z0-9]*]], [[B4:[_A-Za-z][_A-Za-z0-9]*]], [[BS4:[_A-Za-z][_A-Za-z0-9]*]]);
// A5: TMATMUL_MX<pto::AccPhase::Final>([[D5:[_A-Za-z][_A-Za-z0-9]*]], [[C5:[_A-Za-z][_A-Za-z0-9]*]], [[A5:[_A-Za-z][_A-Za-z0-9]*]], [[AS5:[_A-Za-z][_A-Za-z0-9]*]], [[B5:[_A-Za-z][_A-Za-z0-9]*]], [[BS5:[_A-Za-z][_A-Za-z0-9]*]]);
