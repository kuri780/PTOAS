// RUN: not ptoas --pto-arch=a3 %s -o - 2>&1 | FileCheck %s

module {
  func.func @bad_single_line_space(%payload_ptr: !pto.ptr<i32, vec>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    pto.cmo.cacheinvalid %payload_ptr single_cache_line : !pto.ptr<i32, vec>
    return
  }
}

// CHECK: single_cache_line address expects a GM pointer, GM memref, or GM tensor view
