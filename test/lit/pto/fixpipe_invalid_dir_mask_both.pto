// RUN: not ptoas --pto-arch=a5 --pto-level=3 %s 2>&1 | FileCheck %s

module {
  func.func @bad_dir_mask_both(%c2v_buf: i32, %v2c_buf: i32) attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    pto.aic_initialize_pipe {
      id = 0,
      dir_mask = 3,
      slot_size = 1024,
      slot_num = 8,
      nosplit = true,
      acc_push_epilogue = #pto.acc_push_epilogue<
        layout = nz2nd,
        quant = f32_f16,
        relu = no_relu
      >
    } (c2v_consumer_buf = %c2v_buf : i32, v2c_consumer_buf = %v2c_buf : i32)
    return
  }
}

// CHECK: error: 'pto.aic_initialize_pipe' op expects fixpipe pipe (with 'acc_push_epilogue') to have dir_mask = 1 (C2V only)
