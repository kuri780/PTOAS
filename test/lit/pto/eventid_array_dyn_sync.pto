// RUN: ptoas %s 2>&1 | FileCheck %s

module {
  func.func @eventid_array_dyn_sync() {
    %arr = pto.declare_eventid_array -> !pto.eventid_array<4>
    %c0 = arith.constant 0 : index
    %c2 = arith.constant 2 : index
    pto.eventid_array_set %arr[%c0], %c2 : !pto.eventid_array<4>
    %eid = pto.eventid_array_get %arr[%c0] : !pto.eventid_array<4>
    pto.set_flag_dyn [#pto.pipe<PIPE_MTE2>, #pto.pipe<PIPE_MTE3>, %eid]
    pto.wait_flag_dyn [#pto.pipe<PIPE_MTE2>, #pto.pipe<PIPE_MTE3>, %eid]
    return
  }
}

// CHECK-LABEL: AICORE void eventid_array_dyn_sync() {
// CHECK: const int64_t {{[_A-Za-z][_A-Za-z0-9]*}} = 0;
// CHECK: PTOAS_EventIdArray<4> [[ARR_STORAGE:[_A-Za-z][_A-Za-z0-9]*]]
// CHECK: PTOAS_EventIdArray<4> [[ARR:[_A-Za-z][_A-Za-z0-9]*]] = [[ARR_STORAGE]];
// CHECK: [[ARR]][{{[_A-Za-z][_A-Za-z0-9]*}}] = {{[_A-Za-z][_A-Za-z0-9]*}};
// CHECK: int64_t [[EID_SRC:[_A-Za-z][_A-Za-z0-9]*]] = [[ARR]][{{[_A-Za-z][_A-Za-z0-9]*}}];
// CHECK: event_t [[EID:[_A-Za-z][_A-Za-z0-9]*]] = (event_t) [[EID_SRC]];
// CHECK: set_flag(PIPE_MTE2, PIPE_MTE3, [[EID]]);
// CHECK: event_t {{[_A-Za-z][_A-Za-z0-9]*}} = (event_t) [[EID_SRC]];
// CHECK: wait_flag(PIPE_MTE2, PIPE_MTE3, {{[_A-Za-z][_A-Za-z0-9]*}});
