// RUN: ptoas %s | FileCheck %s

module {
  func.func @http_loc_hint(%lhs: i32, %rhs: i32) -> i32 {
    %sum = arith.addi %lhs, %rhs : i32 loc("http://sum")
    %kept = arith.addi %sum, %rhs : i32
    %ret = arith.addi %kept, %sum : i32
    return %ret : i32
  }
}

// CHECK-LABEL: AICORE int32_t http_loc_hint(
// CHECK-NOT: PTOAS_NAME_HINTS
// CHECK-NOT: PTOAS_PROVENANCE
// CHECK: // pto: %http://sum
