// RUN: split-file %s %t
// RUN: not ptoas --pto-arch=a5 %t/no_convert_f16_acc.pto 2>&1 | FileCheck %s --check-prefix=NO_CONVERT_F16_ACC
// RUN: not ptoas --pto-arch=a5 %t/no_convert_i16_acc.pto 2>&1 | FileCheck %s --check-prefix=NO_CONVERT_I16_ACC
// RUN: not ptoas --pto-arch=a5 %t/f32_f16_i32_acc.pto 2>&1 | FileCheck %s --check-prefix=F32_F16_I32_ACC
// RUN: not ptoas --pto-arch=a5 %t/f32_bf16_i32_acc.pto 2>&1 | FileCheck %s --check-prefix=F32_BF16_I32_ACC
// RUN: not ptoas --pto-arch=a5 %t/qf322f16_pre_scalar_i32_acc.pto 2>&1 | FileCheck %s --check-prefix=QF322F16_PRE_I32_ACC
// RUN: not ptoas --pto-arch=a5 %t/req8_scalar_f32_acc.pto 2>&1 | FileCheck %s --check-prefix=REQ8_SCALAR_F32_ACC
// RUN: not ptoas --pto-arch=a5 %t/req8_vec_f32_acc.pto 2>&1 | FileCheck %s --check-prefix=REQ8_VEC_F32_ACC
// RUN: not ptoas --pto-arch=a5 %t/qf322b8_pre_scalar_i32_acc.pto 2>&1 | FileCheck %s --check-prefix=QF322B8_PRE_SCALAR_I32_ACC
// RUN: not ptoas --pto-arch=a5 %t/qf322b8_pre_vec_i32_acc.pto 2>&1 | FileCheck %s --check-prefix=QF322B8_PRE_VEC_I32_ACC
// RUN: not ptoas --pto-arch=a5 %t/qf322bf16_pre_scalar_i32_acc.pto 2>&1 | FileCheck %s --check-prefix=QF322BF16_PRE_I32_ACC
// RUN: not ptoas --pto-arch=a5 %t/qs322bf16_pre_scalar_f32_acc.pto 2>&1 | FileCheck %s --check-prefix=QS322BF16_PRE_SCALAR_F32_ACC
// RUN: not ptoas --pto-arch=a5 %t/qs322bf16_pre_vec_f32_acc.pto 2>&1 | FileCheck %s --check-prefix=QS322BF16_PRE_VEC_F32_ACC
// RUN: not ptoas --pto-arch=a5 %t/qf322hif8_pre_scalar_i32_acc.pto 2>&1 | FileCheck %s --check-prefix=QF322HIF8_PRE_I32_ACC
// RUN: not ptoas --pto-arch=a5 %t/qf322fp8_pre_scalar_i32_acc.pto 2>&1 | FileCheck %s --check-prefix=QF322FP8_PRE_I32_ACC

//--- no_convert_f16_acc.pto
module {
  func.func @cube_kernel() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c0_i32 = arith.constant 0 : i32
    %c2v_import = pto.import_reserved_buffer {name = "c2v_fifo", peer_func = @vector_kernel} -> i32
    pto.aic_initialize_pipe {id = 0, dir_mask = 1, slot_size = 512, nosplit = true,
      acc_push_epilogue = #pto.acc_push_epilogue<layout = nz2nd, quant = no_convert, relu = no_relu>}
      (c2v_consumer_buf = %c2v_import : i32, v2c_consumer_buf = %c0_i32 : i32)
    %acc = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    pto.tpush_to_aiv(%acc : !pto.tile_buf<loc=acc, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>) {id = 0, split = 0}
    return
  }

  func.func @vector_kernel() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0_i32 = arith.constant 0 : i32
    %c2v_local = pto.reserve_buffer {name = "c2v_fifo", size = 4096, location = #pto.address_space<vec>, auto = true} -> i32
    pto.aiv_initialize_pipe {id = 0, dir_mask = 1, slot_size = 512, nosplit = true,
      acc_push_epilogue = #pto.acc_push_epilogue<layout = nz2nd, quant = no_convert, relu = no_relu>}
      (c2v_consumer_buf = %c2v_local : i32, v2c_consumer_buf = %c0_i32 : i32)
    %recv = pto.tpop_from_aic {id = 0, split = 0}
      -> !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tfree_from_aic {id = 0, split = 0}
    return
  }
}

// NO_CONVERT_F16_ACC: error: 'pto.tpush_to_aiv' op expects fixpipe TPUSH source element type to match acc_push_epilogue.quant mode requirements

