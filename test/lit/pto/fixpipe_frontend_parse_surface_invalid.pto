// RUN: split-file %s %t
// RUN: not ptoas --pto-arch=a5 %t/relu_scalar.pto 2>&1 | FileCheck %s --check-prefix=RELU_SCALAR
// RUN: not ptoas --pto-arch=a5 %t/relu_vector.pto 2>&1 | FileCheck %s --check-prefix=RELU_VECTOR
// RUN: not ptoas --pto-arch=a5 %t/relu_pwl.pto 2>&1 | FileCheck %s --check-prefix=RELU_PWL
// RUN: not ptoas --pto-arch=a5 %t/quant_hif8_vec.pto 2>&1 | FileCheck %s --check-prefix=QUANT_HIF8_VEC
// RUN: not ptoas --pto-arch=a5 %t/quant_fp8_vec.pto 2>&1 | FileCheck %s --check-prefix=QUANT_FP8_VEC
// RUN: not ptoas --pto-arch=a5 %t/quant_bf16_vec.pto 2>&1 | FileCheck %s --check-prefix=QUANT_BF16_VEC
// RUN: not ptoas --pto-arch=a5 %t/quant_f16_vec.pto 2>&1 | FileCheck %s --check-prefix=QUANT_F16_VEC
// RUN: not ptoas --pto-arch=a5 %t/quant_f32_pre.pto 2>&1 | FileCheck %s --check-prefix=QUANT_F32_PRE

//--- relu_scalar.pto
module {
  func.func @cube_kernel() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c0_i32 = arith.constant 0 : i32
    pto.aic_initialize_pipe {
      id = 0,
      dir_mask = 1,
      slot_size = 256,
      nosplit = true,
      acc_push_epilogue =
          #pto.acc_push_epilogue<layout = nz2nd, quant = deqf16_scalar, relu = scalar_relu>
    } (c2v_consumer_buf = %c0_i32 : i32, v2c_consumer_buf = %c0_i32 : i32)
    return
  }
}

// RELU_SCALAR: error: expected ::mlir::pto::FixpipeRelu to be one of: no_relu, normal_relu
// RELU_SCALAR: error: failed to parse PTO_AccPushEpilogueAttr parameter 'relu' which is to be a `::mlir::pto::FixpipeRelu`

