// RUN: ptoas %s | FileCheck %s

module {
  func.func @entry(%lhs: i32, %rhs: i32) {
    %0 = func.call @v1(%lhs, %rhs) : (i32, i32) -> i32
    return
  }

  func.func private @v1(%lhs: i32, %rhs: i32) -> i32 {
    %sum = arith.addi %lhs, %rhs : i32 loc("sum")
    return %sum : i32
  }
}

// CHECK-LABEL: AICORE int32_t v1(
// CHECK: return (int32_t)
// CHECK-LABEL: AICORE void entry(
// CHECK: // pto: %0
