module attributes {pto.kernel_kind = #pto.kernel_kind<vector>, pto.mode = "auto", pto.target_arch = "a5"} {
  func.func @_kernel(%arg0: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c32_i32 = arith.constant 32 : i32
    %c1_i32 = arith.constant 1 : i32
    %c1_i32_0 = arith.constant 1 : i32
    pto.simt_launch @_body__simt_0<<<%c32_i32, %c1_i32, %c1_i32_0>>>(%arg0) : (!pto.ptr<f32, gm>) -> ()
    pto.barrier <PIPE_ALL>
    return
  }
  func.func @_body__simt_0(%arg0: !pto.ptr<f32, gm>) attributes {pto.simt_entry} {
    %0 = pto.get_tid_x : i32
    %cst = arith.constant 1.000000e+00 : f32
    %c0_i32 = arith.constant 0 : i32
    %cst_0 = arith.constant 0xFF800000 : f32
    %1 = pto.get_laneid : i32
    %2 = pto.redux_max %cst : f32 -> f32
    %3 = arith.index_cast %0 : i32 to index
    pto.store %2, %arg0[%3] : !pto.ptr<f32, gm>, f32
    return
  }
}
