            %mask_m1_cmg1_1 = pto.pset_b16 "PAT_ALL" : !pto.mask<b16>
            scf.for %offset_m1_cmg1_1 = %c0_m1_cmg1_1 to %c1024_m1_cmg1_1 step %c128_m1_cmg1_1 {
              %lhs_m1_cmg1_1 = pto.vlds %ub_lhs_m1_cmg1_1[%offset_m1_cmg1_1] : !pto.ptr<ui16, ub> -> !pto.vreg<128xui16>
              %rhs_m1_cmg1_1 = pto.vlds %ub_rhs_m1_cmg1_1[%offset_m1_cmg1_1] : !pto.ptr<ui16, ub> -> !pto.vreg<128xui16>
              %out_m1_cmg1_1 = pto.vxor %lhs_m1_cmg1_1, %rhs_m1_cmg1_1, %mask_m1_cmg1_1 : !pto.vreg<128xui16>, !pto.vreg<128xui16>, !pto.mask<b16> -> !pto.vreg<128xui16>
              pto.vsts %out_m1_cmg1_1, %ub_out_m1_cmg1_1[%offset_m1_cmg1_1], %mask_m1_cmg1_1 : !pto.vreg<128xui16>, !pto.ptr<ui16, ub>, !pto.mask<b16>
            }
          }
      
          pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
          pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
          pto.mte_ub_gm %ub_out_m1_cmg1_1, %arg5, %c64_i64_m1_cmg1_1
            nburst(%c32_i64_m1_cmg1_1, %c64_i64_m1_cmg1_1, %c64_i64_m1_cmg1_1)
            : !pto.ptr<ui16, ub>, !pto.ptr<ui16, gm>, i64, i64, i64, i64
          pto.barrier #pto.pipe<PIPE_ALL>
    }

    return
  }
}
