// case: kernels/gemm-residual-rmsnorm-no-c2v
// family: gemm-residual
// data flow (UNFUSED baseline with GM round-trip for GEMM):
//   [Cube] BF16 A/B GM -> L1 -> L0A/L0B -> MAD -> L0C
//   [Cube] L0C -> C2V FIXPIPE split_m -> Vector UB (C2V UB)
//   [Vector] C2V UB -> MTE3 -> GM temp (write GEMM intermediate to GM)
//   [Vector] GM temp -> MTE2 -> UB (read GEMM back from GM to different UB region)
//   [Vector] BF16 Residual GM -> UB; FP32 Gamma GM -> UB
//   [Vector] Pass1: vlds GEMM(from GM) + vlds residual(bf16->f32) -> vadd = x
//            vsts x; vmul x^2; vcadd reduce; accumulate
//   [Vector] Scalar: vmuls(1/N)->vadds(eps)->vsqrt->vdiv(1/root)->vdup->inv_rms
//   [Vector] Pass2: vlds x; vlds gamma; vmul inv_rms; vmul gamma; vsts out
//   [Vector] MTE3: UB -> Output GM
//
// COMPARISON BASELINE: GEMM result intentionally written to and read from GM.
// RMSNorm algorithm identical to fused version (gemm-residual-rmsnorm-c2v-split-m).

module attributes {pto.target_arch = "a5"} {
  func.func @gemm_residual_rmsnorm_no_c2v_kernel(
      %a_gm: !pto.ptr<bf16, gm>,
      %b_gm: !pto.ptr<bf16, gm>,
      %gemm_gm_0: !pto.ptr<f32, gm>,
      %gemm_gm_1: !pto.ptr<f32, gm>,
      %residual_gm_0: !pto.ptr<bf16, gm>,
      %residual_gm_1: !pto.ptr<bf16, gm>,
      %gamma_gm: !pto.ptr<f32, gm>,
      %out_gm_0: !pto.ptr<f32, gm>,
      %out_gm_1: !pto.ptr<f32, gm>)
    attributes {pto.kernel} {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c8_i64 = arith.constant 8 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64
    %c64_i64 = arith.constant 64 : i64
    %c128_i64 = arith.constant 128 : i64
    %c256_i64 = arith.constant 256 : i64
    %c512_i64 = arith.constant 512 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c2048_i64 = arith.constant 2048 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c20480_i64 = arith.constant 20480 : i64

    %false = arith.constant false

    // L1 / L0 pointers
    %l1_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<bf16, l1>
    %l1_b = pto.castptr %c4096_i64 : i64 -> !pto.ptr<bf16, l1>
    %l0a = pto.castptr %c0_i64 : i64 -> !pto.ptr<bf16, l0a>
    %l0b = pto.castptr %c0_i64 : i64 -> !pto.ptr<bf16, l0b>
    %l0c = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, l0c>

    // UB layout per subblock (8 rows x 256 cols):
    //   [0, 8192):     C2V GEMM FP32 tile [8,256] (source for GM write)
    //   [8192, 16384): GEMM FP32 loaded back from GM [8,256] (used by RMSNorm)
    //   [16384, 20480): Residual BF16 [8,256]
    //   [20480, 21504): Gamma FP32 [256]
    %ub_c2v = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_gemm = pto.castptr %c8192_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_residual_bf16 = pto.castptr %c16384_i64 : i64 -> !pto.ptr<bf16, ub>
    %ub_gamma = pto.castptr %c20480_i64 : i64 -> !pto.ptr<f32, ub>

    // =======================================================================
    // Cube section (same as fused)
    // =======================================================================
    pto.section.cube {
      // A: bf16[16,64] -> L1
      pto.mte_gm_l1_frac %a_gm, %l1_a, nd2nz,
          shape(%c16_i64, %c64_i64),
          src_layout(%c128_i64),
          dst_group(%c1_i64, %c1_i64, %c16_i64, %c0_i64),
          ctrl(%c0_i64, %false)
        : !pto.ptr<bf16, gm>, !pto.ptr<bf16, l1>, nd2nz,
          shape i64, i64, src_layout(i64),
          dst_group i64, i64, i64, i64, ctrl i64, i1
      // B: bf16[64,256] -> L1
      pto.mte_gm_l1_frac %b_gm, %l1_b, nd2nz,
          shape(%c64_i64, %c256_i64),
          src_layout(%c512_i64),
          dst_group(%c1_i64, %c1_i64, %c64_i64, %c0_i64),
          ctrl(%c0_i64, %false)
        : !pto.ptr<bf16, gm>, !pto.ptr<bf16, l1>, nd2nz,
          shape i64, i64, src_layout(i64),
          dst_group i64, i64, i64, i64, ctrl i64, i1

      // L1 -> L0A/L0B
      pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
      pto.mte_l1_l0a %l1_a, %l0a, %c16_i64, %c64_i64, %c0_i64, %c0_i64
        : !pto.ptr<bf16, l1>, !pto.ptr<bf16, l0a>, i64, i64, i64, i64
      pto.mte_l1_l0b %l1_b, %l0b, %c64_i64, %c256_i64, %c0_i64, %c0_i64 {transpose = true}
        : !pto.ptr<bf16, l1>, !pto.ptr<bf16, l0b>, i64, i64, i64, i64

      // MAD: BF16*BF16 -> FP32 L0C [16,256]
      pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
      pto.mad %l0a, %l0b, %l0c, %c16_i64, %c256_i64, %c64_i64
        : !pto.ptr<bf16, l0a>, !pto.ptr<bf16, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

      // L0C -> UB via FIXPIPE split_m -> 2x[8,256]
      pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
      pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
      pto.set_flag["PIPE_MTE2", "PIPE_FIX", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE2", "PIPE_FIX", "EVENT_ID0"]
      pto.mte_l0c_ub %l0c, %ub_c2v, %c16_i64, %c256_i64, %c16_i64, %c256_i64,
        dst_mode(split_m),
        nz2nd,
        sat
        : !pto.ptr<f32, l0c>, !pto.ptr<f32, ub>, i64, i64, i64, i64

      // Notify vector subblocks
      pto.sync.set <PIPE_FIX>, 1
      pto.sync.set <PIPE_FIX>, 17
    }

    // =======================================================================
    // Vector section (GM round-trip GEMM + RMSNorm)
    // =======================================================================
    pto.section.vector {
      %subblock = pto.get_subblock_idx
      %is_subblock0 = arith.cmpi eq, %subblock, %c0_i64 : i64
      %is_subblock1 = arith.cmpi eq, %subblock, %c1_i64 : i64

      // ---------------------------------------------------------------
      // V1: Wait for C2V data in UB
      // ---------------------------------------------------------------
      pto.sync.wait <PIPE_MTE3>, 1
      pto.set_flag["PIPE_MTE3", "PIPE_V", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE3", "PIPE_V", "EVENT_ID0"]

      // ---------------------------------------------------------------
      // V2: Write GEMM from UB → GM temp (MTE3) — GM ROUND-TRIP WRITE
      // ---------------------------------------------------------------
      pto.get_buf "PIPE_MTE3", 0, 0
      scf.if %is_subblock0 {
        pto.mte_ub_gm %ub_c2v, %gemm_gm_0, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
      }
      scf.if %is_subblock1 {
        pto.mte_ub_gm %ub_c2v, %gemm_gm_1, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
      }
      pto.rls_buf "PIPE_MTE3", 0, 0

      // ---------------------------------------------------------------
      // V3: Load GEMM back from GM → UB (MTE2) — GM ROUND-TRIP READ
      // ---------------------------------------------------------------
      pto.set_flag["PIPE_MTE3", "PIPE_MTE2", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE3", "PIPE_MTE2", "EVENT_ID0"]
      pto.get_buf "PIPE_MTE2", 0, 0
      scf.if %is_subblock0 {
        pto.mte_gm_ub %gemm_gm_0, %ub_gemm, %c0_i64, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64
      }
      scf.if %is_subblock1 {
        pto.mte_gm_ub %gemm_gm_1, %ub_gemm, %c0_i64, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64
      }
      pto.rls_buf "PIPE_MTE2", 0, 0

      // ---------------------------------------------------------------
      // V4: Load BF16 residual [8,256] from GM → UB (MTE2, buffer 1)
      // ---------------------------------------------------------------
      pto.get_buf "PIPE_MTE2", 1, 0
      scf.if %is_subblock0 {
        pto.mte_gm_ub %residual_gm_0, %ub_residual_bf16, %c0_i64, %c512_i64
          nburst(%c8_i64, %c512_i64, %c512_i64)
          : !pto.ptr<bf16, gm>, !pto.ptr<bf16, ub>, i64, i64, i64, i64, i64
      }
      scf.if %is_subblock1 {
        pto.mte_gm_ub %residual_gm_1, %ub_residual_bf16, %c0_i64, %c512_i64
          nburst(%c8_i64, %c512_i64, %c512_i64)
          : !pto.ptr<bf16, gm>, !pto.ptr<bf16, ub>, i64, i64, i64, i64, i64
      }
      pto.rls_buf "PIPE_MTE2", 1, 0

      // ---------------------------------------------------------------
      // V5: Load FP32 gamma [256] from GM → UB (MTE2, buffer 2)
      // ---------------------------------------------------------------
      pto.get_buf "PIPE_MTE2", 2, 0
      pto.mte_gm_ub %gamma_gm, %ub_gamma, %c0_i64, %c1024_i64
        nburst(%c1_i64, %c1024_i64, %c1024_i64)
        : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64
      pto.rls_buf "PIPE_MTE2", 2, 0

      // ---------------------------------------------------------------
      // V6: Signal MTE2 → V (all data ready)
      // ---------------------------------------------------------------
      pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

      pto.get_buf "PIPE_V", 0, 0
      pto.get_buf "PIPE_V", 1, 0
      pto.get_buf "PIPE_V", 2, 0

      // ---------------------------------------------------------------
      // V7: RMSNorm (same algorithm as fused, using ub_gemm for GEMM data)
      // ---------------------------------------------------------------
      pto.vecscope {
        %c0_idx = arith.constant 0 : index
        %c64_idx = arith.constant 64 : index
        %c256_idx = arith.constant 256 : index
        %c1_i32 = arith.constant 1 : i32
        %c64_i32 = arith.constant 64 : i32
        %c256_i32 = arith.constant 256 : i32

        %cvt_b16 = pto.pset_b16 "PAT_ALL" : !pto.mask<b16>
        %full_b32 = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>

        %cst_zero = arith.constant 0.000000e+00 : f32
        %cst_one = arith.constant 1.000000e+00 : f32
        %cst_invN = arith.constant 3.906250e-03 : f32   // 1/256
        %cst_eps = arith.constant 1.000000e-06 : f32

        // ================================================================
        // Row loop: 8 rows, 256 cols each
        // ================================================================
        %c2048_idx = arith.constant 2048 : index
        scf.for %row_base = %c0_idx to %c2048_idx step %c256_idx {
          // ---- Accumulator for sum-of-squares ----
          %acc0 = pto.vbr %cst_zero : f32 -> !pto.vreg<64xf32>

          // ---- One-lane mask for accumulation ----
          %one_mask, %_one_rem = pto.plt_b32 %c1_i32 : i32 -> !pto.mask<b32>, i32

          // ==============================================================
          // Pass 1: compute x = GEMM + residual, save x, accumulate x^2
          // (uses ub_gemm for GEMM data loaded back from GM)
          // ==============================================================
          %p1_acc, %p1_rem = scf.for %chunk_p1 = %c0_idx to %c256_idx step %c64_idx
              iter_args(%acc = %acc0, %rem = %c256_i32)
                -> (!pto.vreg<64xf32>, i32) {
            %gemm_offset = arith.addi %row_base, %chunk_p1 : index
            %res_offset = arith.addi %row_base, %chunk_p1 : index
            %b32mask, %next_rem = pto.plt_b32 %rem : i32 -> !pto.mask<b32>, i32

            // Load GEMM result from ub_gemm (loaded back from GM)
            %gemm_val = pto.vlds %ub_gemm[%gemm_offset]
              : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>

            // Load residual BF16 and convert to f32
            %res_bf16 = pto.vlds %ub_residual_bf16[%res_offset] {dist = "UNPK_B16"}
              : !pto.ptr<bf16, ub> -> !pto.vreg<128xbf16>
            %res_f32 = pto.vcvt %res_bf16, %cvt_b16 {part = "EVEN"}
              : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<64xf32>

            // x = GEMM + residual
            %x = pto.vadd %gemm_val, %res_f32, %b32mask
              : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>

            // Save x to ub_gemm for pass 2
            pto.vsts %x, %ub_gemm[%gemm_offset], %b32mask
              : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>

            // square = x * x
            %square = pto.vmul %x, %x, %b32mask
              : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>

            // Reduce square to lowest lane (64→1)
            %chunk_sum = pto.vcadd %square, %b32mask
              : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>

            // Accumulate: acc += chunk_sum (only lane 0 via one_mask)
            %new_acc = pto.vadd %acc, %chunk_sum, %one_mask
              : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>

            scf.yield %new_acc, %next_rem : !pto.vreg<64xf32>, i32
          }

          // ==============================================================
          // RMSNorm scalar chain (operates on lane 0 only via one_mask)
          // ==============================================================

          // mean_sq = sum / N
          %mean_sq = pto.vmuls %p1_acc, %cst_invN, %one_mask
            : !pto.vreg<64xf32>, f32, !pto.mask<b32> -> !pto.vreg<64xf32>

          // variance = mean_sq + epsilon
          %variance = pto.vadds %mean_sq, %cst_eps, %one_mask
            : !pto.vreg<64xf32>, f32, !pto.mask<b32> -> !pto.vreg<64xf32>

          // root = sqrt(variance)
          %root = pto.vsqrt %variance, %one_mask
            : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>

          // inv_rms = 1 / root
          %one_vec = pto.vbr %cst_one : f32 -> !pto.vreg<64xf32>
          %inv_rms = pto.vdiv %one_vec, %root, %one_mask
            : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>

          // Broadcast inv_rms from lane 0 to all lanes
          %inv_rms_bc = pto.vdup %inv_rms, %full_b32 {position = "LOWEST"}
            : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>

          // ==============================================================
          // Pass 2: apply inv_rms * gamma
          // ==============================================================
          %p2_rem = scf.for %chunk_p2 = %c0_idx to %c256_idx step %c64_idx
              iter_args(%rem2 = %c256_i32) -> (i32) {
            %gemm_offset2 = arith.addi %row_base, %chunk_p2 : index
            %b32mask2, %next_rem2 = pto.plt_b32 %rem2 : i32 -> !pto.mask<b32>, i32

            // Reload x from ub_gemm
            %x_val = pto.vlds %ub_gemm[%gemm_offset2]
              : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>

            // Load gamma chunk
            %gamma_val = pto.vlds %ub_gamma[%chunk_p2]
              : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>

            // normed = x * inv_rms
            %normed = pto.vmul %x_val, %inv_rms_bc, %b32mask2
              : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>

            // output = normed * gamma
            %output = pto.vmul %normed, %gamma_val, %b32mask2
              : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>

            // Store final output to ub_gemm
            pto.vsts %output, %ub_gemm[%gemm_offset2], %b32mask2
              : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>

            scf.yield %next_rem2 : i32
          }
        }
      }

      pto.rls_buf "PIPE_V", 0, 0
      pto.rls_buf "PIPE_V", 1, 0
      pto.rls_buf "PIPE_V", 2, 0

      // ---------------------------------------------------------------
      // V8: Signal V → MTE3
      // ---------------------------------------------------------------
      pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
      pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]

      // ---------------------------------------------------------------
      // V9: Write FP32 result [8,256] to Output GM
      // ---------------------------------------------------------------
      pto.get_buf "PIPE_MTE3", 2, 0
      scf.if %is_subblock0 {
        pto.mte_ub_gm %ub_gemm, %out_gm_0, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
      }
      scf.if %is_subblock1 {
        pto.mte_ub_gm %ub_gemm, %out_gm_1, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
      }
      pto.rls_buf "PIPE_MTE3", 2, 0
      pto.barrier #pto.pipe<PIPE_ALL>
    }
    return
  }
}
