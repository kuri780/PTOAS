// -----------------------------------------------------------------------------
// case: kernels/gemm-residual-no-c2v
// family: gemm-residual (non-fused baseline with GM round-trip)
//
// Data flow (GM round-trip for GEMM — comparison baseline for C2V fused):
//   [Cube]  BF16 A/B → MAD → FP32 L0C
//   [Cube]  L0C → C2V split_m → UB (reliable on-chip path)
//   [Vector] UB → MTE3 → GM (write GEMM intermediate to GM)
//   [Vector] GM → MTE2 → UB (load GEMM back from GM)
//   [Vector] GM → MTE2 → UB (load BF16 residual)
//   [Vector] vcvt BF16→FP32 + VADD → MTE3 → Output GM
//
// NOTE: This version deliberately writes and reads GEMM through GM.
// Serves as the non-fused baseline for msprof comparison.
// Uses C2V→UB→GM→UB path to avoid nz2nd format mismatch.
// -----------------------------------------------------------------------------

module attributes {pto.target_arch = "a5"} {
  func.func @gemm_residual_no_c2v_kernel(
      %a_gm: !pto.ptr<bf16, gm>,
      %b_gm: !pto.ptr<bf16, gm>,
      %gemm_gm_0: !pto.ptr<f32, gm>,
      %gemm_gm_1: !pto.ptr<f32, gm>,
      %residual_gm_0: !pto.ptr<bf16, gm>,
      %residual_gm_1: !pto.ptr<bf16, gm>,
      %out_gm_0: !pto.ptr<f32, gm>,
      %out_gm_1: !pto.ptr<f32, gm>)
    attributes {pto.kernel} {
    // ── constants ──────────────────────────────────────────────────────────
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c8_i64 = arith.constant 8 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64
    %c64_i64 = arith.constant 64 : i64
    %c128_i64 = arith.constant 128 : i64
    %c256_i64 = arith.constant 256 : i64
    %c512_i64 = arith.constant 512 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c2048_i64 = arith.constant 2048 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c16384_i64 = arith.constant 16384 : i64

    %false = arith.constant false

    // ── memory layout ──────────────────────────────────────────────────────
    // L1
    %l1_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<bf16, l1>
    %l1_b = pto.castptr %c4096_i64 : i64 -> !pto.ptr<bf16, l1>
    // L0
    %l0a = pto.castptr %c0_i64 : i64 -> !pto.ptr<bf16, l0a>
    %l0b = pto.castptr %c0_i64 : i64 -> !pto.ptr<bf16, l0b>
    %l0c = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, l0c>

    // UB layout per subblock:
    //   [0,      8192): C2V GEMM FP32 tile [8,256]  (then MTE3→GM)
    //   [8192,  16384): GEMM FP32 loaded back from GM [8,256]
    //   [16384, 20480): Residual BF16 from GM [8,256]
    %ub_c2v = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_gemm = pto.castptr %c8192_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_residual_bf16 = pto.castptr %c16384_i64 : i64 -> !pto.ptr<bf16, ub>

    // ── cube section: C2V split_m → UB (same as fused) ────────────────────
    pto.section.cube {
      pto.mte_gm_l1_frac %a_gm, %l1_a, nd2nz,
          shape(%c16_i64, %c64_i64),
          src_layout(%c128_i64),
          dst_group(%c1_i64, %c1_i64, %c16_i64, %c0_i64),
          ctrl(%c0_i64, %false)
        : !pto.ptr<bf16, gm>, !pto.ptr<bf16, l1>, nd2nz,
          shape i64, i64, src_layout(i64),
          dst_group i64, i64, i64, i64, ctrl i64, i1
      pto.mte_gm_l1_frac %b_gm, %l1_b, nd2nz,
          shape(%c64_i64, %c256_i64),
          src_layout(%c512_i64),
          dst_group(%c1_i64, %c1_i64, %c64_i64, %c0_i64),
          ctrl(%c0_i64, %false)
        : !pto.ptr<bf16, gm>, !pto.ptr<bf16, l1>, nd2nz,
          shape i64, i64, src_layout(i64),
          dst_group i64, i64, i64, i64, ctrl i64, i1

      pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
      pto.mte_l1_l0a %l1_a, %l0a, %c16_i64, %c64_i64, %c0_i64, %c0_i64
        : !pto.ptr<bf16, l1>, !pto.ptr<bf16, l0a>, i64, i64, i64, i64
      pto.mte_l1_l0b %l1_b, %l0b, %c64_i64, %c256_i64, %c0_i64, %c0_i64 {transpose = true}
        : !pto.ptr<bf16, l1>, !pto.ptr<bf16, l0b>, i64, i64, i64, i64

      pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
      pto.mad %l0a, %l0b, %l0c, %c16_i64, %c256_i64, %c64_i64
        : !pto.ptr<bf16, l0a>, !pto.ptr<bf16, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

      pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
      pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
      pto.set_flag["PIPE_MTE2", "PIPE_FIX", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE2", "PIPE_FIX", "EVENT_ID0"]
      pto.mte_l0c_ub %l0c, %ub_c2v, %c16_i64, %c256_i64, %c16_i64, %c256_i64,
        dst_mode(split_m),
        nz2nd,
        sat
        : !pto.ptr<f32, l0c>, !pto.ptr<f32, ub>, i64, i64, i64, i64

      pto.sync.set <PIPE_FIX>, 1
      pto.sync.set <PIPE_FIX>, 17
    }

    // ── vector section: GM round-trip GEMM + residual add ──────────────────
    pto.section.vector {
      %subblock = pto.get_subblock_idx
      %is_subblock0 = arith.cmpi eq, %subblock, %c0_i64 : i64
      %is_subblock1 = arith.cmpi eq, %subblock, %c1_i64 : i64

      // --- V1: wait for C2V, notify V pipeline -----------------------------
      pto.sync.wait <PIPE_MTE3>, 1
      pto.set_flag["PIPE_MTE3", "PIPE_V", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE3", "PIPE_V", "EVENT_ID0"]

      // --- V2: write GEMM from UB → GM temp (MTE3, buffer 0) ---------------
      pto.get_buf "PIPE_MTE3", 0, 0
      scf.if %is_subblock0 {
        pto.mte_ub_gm %ub_c2v, %gemm_gm_0, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
      }
      scf.if %is_subblock1 {
        pto.mte_ub_gm %ub_c2v, %gemm_gm_1, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
      }
      pto.rls_buf "PIPE_MTE3", 0, 0

      // --- V3: load GEMM back from GM → UB (MTE2, buffer 0) ----------------
      pto.set_flag["PIPE_MTE3", "PIPE_MTE2", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE3", "PIPE_MTE2", "EVENT_ID0"]
      pto.get_buf "PIPE_MTE2", 0, 0
      scf.if %is_subblock0 {
        pto.mte_gm_ub %gemm_gm_0, %ub_gemm, %c0_i64, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64
      }
      scf.if %is_subblock1 {
        pto.mte_gm_ub %gemm_gm_1, %ub_gemm, %c0_i64, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64
      }
      pto.rls_buf "PIPE_MTE2", 0, 0

      // --- V4: load BF16 residual from GM → UB (MTE2, buffer 1) ------------
      pto.get_buf "PIPE_MTE2", 1, 0
      scf.if %is_subblock0 {
        pto.mte_gm_ub %residual_gm_0, %ub_residual_bf16, %c0_i64, %c512_i64
          nburst(%c8_i64, %c512_i64, %c512_i64)
          : !pto.ptr<bf16, gm>, !pto.ptr<bf16, ub>, i64, i64, i64, i64, i64
      }
      scf.if %is_subblock1 {
        pto.mte_gm_ub %residual_gm_1, %ub_residual_bf16, %c0_i64, %c512_i64
          nburst(%c8_i64, %c512_i64, %c512_i64)
          : !pto.ptr<bf16, gm>, !pto.ptr<bf16, ub>, i64, i64, i64, i64, i64
      }
      pto.rls_buf "PIPE_MTE2", 1, 0

      // --- V5: signal MTE2→V for both loads --------------------------------
      pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
      pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

      // --- V6: BF16→FP32 conversion + VADD (Vector) ------------------------
      pto.get_buf "PIPE_V", 0, 0
      pto.get_buf "PIPE_V", 1, 0
      pto.get_buf "PIPE_V", 2, 0

      pto.vecscope {
        %c0_idx = arith.constant 0 : index
        %c64_idx = arith.constant 64 : index
        %c2048_idx = arith.constant 2048 : index
        %init_remaining = arith.constant 2048 : i32
        %cvt_mask = pto.pset_b16 "PAT_ALL" : !pto.mask<b16>

        %loop_result = scf.for %offset = %c0_idx to %c2048_idx step %c64_idx
            iter_args(%remaining = %init_remaining) -> (i32) {
          %mask, %next_remaining = pto.plt_b32 %remaining : i32 -> !pto.mask<b32>, i32
          %loaded = pto.vlds %ub_residual_bf16[%offset] {dist = "UNPK_B16"}
            : !pto.ptr<bf16, ub> -> !pto.vreg<128xbf16>
          %converted = pto.vcvt %loaded, %cvt_mask {part = "EVEN"}
            : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<64xf32>
          %gemm_tile = pto.vlds %ub_gemm[%offset]
            : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
          %sum = pto.vadd %gemm_tile, %converted, %mask
            : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>
          pto.vsts %sum, %ub_gemm[%offset], %mask
            : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
          scf.yield %next_remaining : i32
        }
      }

      pto.rls_buf "PIPE_V", 0, 0
      pto.rls_buf "PIPE_V", 1, 0
      pto.rls_buf "PIPE_V", 2, 0

      // --- V7: signal V→MTE3 -----------------------------------------------
      pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
      pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]

      // --- V8: write final result to Output GM (MTE3) ----------------------
      pto.get_buf "PIPE_MTE3", 2, 0
      scf.if %is_subblock0 {
        pto.mte_ub_gm %ub_gemm, %out_gm_0, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
      }
      scf.if %is_subblock1 {
        pto.mte_ub_gm %ub_gemm, %out_gm_1, %c1024_i64
          nburst(%c8_i64, %c1024_i64, %c1024_i64)
          : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
      }
      pto.rls_buf "PIPE_MTE3", 2, 0
      pto.barrier #pto.pipe<PIPE_ALL>
    }
    return
  }
}
